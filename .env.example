# GEMINI_API_KEY — Required for AI insights (Google Gemini).
# Get a free key at https://ai.google.dev/  →  "Get API key"
GEMINI_API_KEY=your-gemini-api-key-here

# PORT — HTTP port the Express server binds to (default 3000).
# On Hugging Face Spaces this MUST be 7860. Other hosts (Render, Railway) inject
# their own PORT env var automatically — don't override unless you know why.
PORT=3000

# NODE_ENV — set to "production" on deploys to skip Vite dev middleware.
NODE_ENV=development

# APP_URL — public URL where this app is hosted (used for self-referential links).
APP_URL=http://localhost:3000
